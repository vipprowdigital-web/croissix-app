{
  "expo": {
    "name": "croissix",
    "slug": "croissix",
    "scheme": "croissix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo/app-logo.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.vipprow.croissix",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#2a0e45",
        "foregroundImage": "./assets/images/logo/app-logo.png"
        // "backgroundImage": "./assets/images/splash.png",
        // "monochromeImage": "./assets/images/splash.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "croissix"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo/app-logo.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-router",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo/croissix-app-logo.png",
          "imageWidth": 200,
          "resizeMode": "cover",
          "backgroundColor": "#2a0e45"
          // "dark": {
          //   "backgroundColor": "#2a0e45"
          // }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them in posts."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4fa143af-77be-4167-ab70-fd4648862f38"
      }
    }
  }
}
